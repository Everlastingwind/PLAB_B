{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "dota2planb.com" }],
      "destination": "https://www.dota2planb.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/data/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!data/|assets/|images/|favicon\\.ico|favicon\\.png|robots\\.txt|sitemap\\.xml|dota-a-mark\\.png|planb-logo-transparent\\.png).*)",
      "destination": "/index.html"
    }
  ]
}
